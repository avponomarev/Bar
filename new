import re
import json
import time
import argparse
from dataclasses import dataclass
from typing import List, Optional, Tuple, Dict, Set
from urllib.parse import urljoin, urlparse, urldefrag

import requests
import pandas as pd
import tldextract
from bs4 import BeautifulSoup, Tag


DEFAULT_HEADERS = {
    "User-Agent": (
        "Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 "
        "(KHTML, like Gecko) Chrome/122.0 Safari/537.36"
    ),
    "Accept-Language": "ru,en;q=0.8,de;q=0.7,fr;q=0.6,it;q=0.6,es;q=0.6",
}

BAD_SCHEMES = ("mailto:", "tel:", "javascript:")

MENU_KEYWORDS = re.compile(
    r"\b("
    r"menu|our menu|food|drinks|wine|cocktail|bar|kitchen|"
    r"speisekarte|getr[aä]nke|mittag|abend|"
    r"karte|weinkarte|"
    r"carta|men[uú]|bebidas|"
    r"carte|boissons|"
    r"меню|напитки|бар|кухня|винная карта|"
    r")\b",
    re.IGNORECASE,
)

# признаки "цен"
PRICE_RE = re.compile(
    r"(?<!\w)("
    r"(?:€|\$|£)\s?\d{1,4}(?:[.,]\d{1,2})?"
    r"|\d{1,4}(?:[.,]\d{1,2})?\s?(?:€|eur|euro|руб\.?|р\.?|₽|usd|gbp)"
    r")",
    re.IGNORECASE,
)

# Иногда цены пишутся как "12,-" или "12,50"
PRICE_SIMPLE_RE = re.compile(r"\b\d{1,3}(?:[.,]\d{1,2})?\s?(?:€|eur|euro|₽|руб\.?|р\.?)\b", re.IGNORECASE)
PRICE_BARE_RE = re.compile(r"\b\d{1,3}(?:[.,]\d{1,2})\b")  # осторожно: может ловить не цены

def norm_space(s: str) -> str:
    return re.sub(r"\s+", " ", (s or "")).strip()

def get_reg_domain(url: str) -> str:
    e = tldextract.extract(url)
    return ".".join([p for p in [e.domain, e.suffix] if p]).lower()

def is_internal(base_url: str, u: str) -> bool:
    return get_reg_domain(base_url) == get_reg_domain(u)

def canonicalize_url(base_url: str, href: str) -> Optional[str]:
    if not href:
        return None
    href = href.strip()
    low = href.lower()
    if any(low.startswith(s) for s in BAD_SCHEMES):
        return None
    abs_url = urljoin(base_url, href)
    abs_url, _ = urldefrag(abs_url)
    p = urlparse(abs_url)
    if p.scheme not in ("http", "https"):
        return None
    return abs_url

def looks_like_file(path: str) -> bool:
    path = (path or "").lower()
    return any(path.endswith(ext) for ext in [".pdf", ".jpg", ".jpeg", ".png", ".webp", ".svg", ".zip", ".mp4"])

def url_is_pdf(url: str) -> bool:
    return urlparse(url).path.lower().endswith(".pdf")


@dataclass
class MenuItem:
    site: str
    start_url: str
    source_url: str
    category: Optional[str]
    name: str
    description: Optional[str]
    price: Optional[str]


class RestaurantMenuScraper:
    def __init__(self, timeout: int = 20, sleep_sec: float = 0.3, retries: int = 2):
        self.timeout = timeout
        self.sleep_sec = sleep_sec
        self.retries = retries
        self.sess = requests.Session()
        self.sess.headers.update(DEFAULT_HEADERS)

    def fetch(self, url: str) -> Optional[requests.Response]:
        last_err = None
        for attempt in range(self.retries + 1):
            try:
                r = self.sess.get(url, timeout=self.timeout, allow_redirects=True)
                if r.status_code >= 400:
                    last_err = f"HTTP {r.status_code}"
                    time.sleep(0.2 * (attempt + 1))
                    continue
                return r
            except Exception as e:
                last_err = str(e)
                time.sleep(0.3 * (attempt + 1))
        return None

    def fetch_html(self, url: str) -> Optional[str]:
        r = self.fetch(url)
        time.sleep(self.sleep_sec)
        if not r:
            return None
        # иногда content-type отсутствует/кривой — всё равно попробуем как html
        return r.text

    def collect_internal_pages(self, start_url: str, max_pages: int = 35) -> List[str]:
        """
        BFS по внутренним ссылкам, чтобы найти кандидатов меню.
        """
        if not re.match(r"^https?://", start_url, re.IGNORECASE):
            start_url = "https://" + start_url

        q = [start_url]
        seen = {start_url}
        out = []

        while q and len(out) < max_pages:
            url = q.pop(0)
            html = self.fetch_html(url)
            if not html:
                continue
            out.append(url)

            soup = BeautifulSoup(html, "lxml")
            for a in soup.select("a[href]"):
                abs_url = canonicalize_url(url, a.get("href"))
                if not abs_url:
                    continue
                if not is_internal(start_url, abs_url):
                    continue

                path = urlparse(abs_url).path
                # не выкидываем pdf, он может быть меню — но не будем по нему BFS продолжать
                if looks_like_file(path) and not url_is_pdf(abs_url):
                    continue

                if abs_url not in seen:
                    seen.add(abs_url)
                    q.append(abs_url)

        return out

    def find_menu_candidates(self, start_url: str, pages: List[str], max_candidates: int = 12) -> List[str]:
        """
        Отбираем URL-ы, которые похожи на страницу/файл меню:
        - по анкор-текстам/URL (menu, speisekarte, drinks...)
        - плюс анализ контента: много цен на странице
        """
        candidates: Set[str] = set()

        # 1) кандидаты из ссылок на страницах (по ключевым словам)
        for p in pages:
            html = self.fetch_html(p)
            if not html:
                continue
            soup = BeautifulSoup(html, "lxml")
            for a in soup.select("a[href]"):
                text = norm_space(a.get_text(" ", strip=True))
                href = a.get("href")
                abs_url = canonicalize_url(p, href)
                if not abs_url:
                    continue
                if not is_internal(start_url, abs_url):
                    continue

                in_text = bool(text and MENU_KEYWORDS.search(text))
                in_url = bool(MENU_KEYWORDS.search(abs_url))
                if in_text or in_url:
                    candidates.add(abs_url)

        # 2) если мало — добавим “типичные” пути
        typical = ["/menu", "/menue", "/speisekarte", "/karte", "/food", "/drinks", "/bar", "/carta", "/carte", "/меню"]
        for t in typical:
            candidates.add(urljoin(start_url, t))

        # 3) скоринг: страница меню обычно содержит много цен
        scored: List[Tuple[int, str]] = []
        for u in list(candidates):
            r = self.fetch(u)
            time.sleep(self.sleep_sec)
            if not r:
                continue
            ctype = (r.headers.get("Content-Type") or "").lower()

            if "application/pdf" in ctype or url_is_pdf(u):
                # PDF меню — это прям очень сильный кандидат
                scored.append((1000, u))
                continue

            # HTML/прочее
            text = r.text
            price_hits = len(PRICE_RE.findall(text))
            kw_hits = len(MENU_KEYWORDS.findall((r.text[:20000] or "")))  # слегка
            # лёгкий бонус, если url содержит menu
            url_bonus = 5 if MENU_KEYWORDS.search(u) else 0
            score = price_hits * 8 + kw_hits * 2 + url_bonus
            scored.append((score, u))

        scored.sort(key=lambda x: x[0], reverse=True)
        # отбросим совсем слабые
        strong = [u for s, u in scored if s >= 25][:max_candidates]
        # если вообще ничего сильного — вернём топ-3 как “best effort”
        return strong if strong else [u for _, u in scored[:3]]

    # ----------------------------
    # Извлечение позиций меню (HTML)
    # ----------------------------

    def extract_from_html(self, start_url: str, source_url: str, html: str) -> List[MenuItem]:
        soup = BeautifulSoup(html, "lxml")

        # уберём очевидный шум
        for t in soup(["script", "style", "noscript"]):
            t.decompose()

        site = urlparse(start_url).netloc

        items: List[MenuItem] = []

        # 1) Попробуем структурные паттерны: таблицы/карточки/листы
        # Ищем элементы, где есть цена и рядом текст
        # Будем собирать по блокам, содержащим цену.
        price_nodes = []
        for node in soup.find_all(text=PRICE_RE):
            if isinstance(node, str):
                price_nodes.append(node.parent)

        def nearest_block(tag: Tag) -> Tag:
            cur = tag
            # поднимаемся до разумного контейнера
            for _ in range(4):
                if not isinstance(cur, Tag):
                    break
                if cur.name in {"li", "tr", "article", "section", "div"}:
                    return cur
                cur = cur.parent
            return tag

        seen_blocks = set()
        for pn in price_nodes:
            if not isinstance(pn, Tag):
                continue
            block = nearest_block(pn)
            bid = id(block)
            if bid in seen_blocks:
                continue
            seen_blocks.add(bid)

            block_text = norm_space(block.get_text(" ", strip=True))
            if not block_text:
                continue

            prices = PRICE_RE.findall(block_text)
            price = prices[0] if prices else None

            # попытка выделить имя блюда:
            # возьмём первый "сильный" текстовый кусок до цены
            before = block_text
            if price:
                idx = before.find(price)
                if idx > 0:
                    before = before[:idx].strip()

            # имя — обычно первая фраза, описание — остаток
            # разделим по " — " / ":" / "  " и т.п.
            name = None
            desc = None

            # если внутри есть явный заголовок
            heading = block.find(["h1", "h2", "h3", "h4", "strong"])
            if heading:
                htxt = norm_space(heading.get_text(" ", strip=True))
                if htxt and len(htxt) <= 80:
                    name = htxt

            if not name:
                # fallback: первый “кусок” до разделителя
                parts = re.split(r"\s[-–—:]\s|\s{2,}", before, maxsplit=1)
                name = norm_space(parts[0])[:120] if parts and parts[0] else None
                if len(parts) > 1:
                    desc = norm_space(parts[1])[:400]

            if not name or len(name) < 2:
                continue

            # категория (если есть ближайший заголовок выше по дереву)
            cat = None
            parent = block
            for _ in range(6):
                if not isinstance(parent, Tag):
                    break
                prev = parent.find_previous(["h2", "h3"])
                if prev:
                    c = norm_space(prev.get_text(" ", strip=True))
                    if c and len(c) <= 60:
                        cat = c
                        break
                parent = parent.parent

            items.append(
                MenuItem(
                    site=site,
                    start_url=start_url,
                    source_url=source_url,
                    category=cat,
                    name=name,
                    description=desc,
                    price=price,
                )
            )

        # 2) Если почти ничего не нашли — fallback по строкам текста
        if len(items) < 5:
            text = soup.get_text("\n", strip=True)
            lines = [norm_space(x) for x in text.splitlines() if norm_space(x)]
            # простая эвристика: "Название ... 12,50 €"
            for ln in lines:
                if not PRICE_RE.search(ln):
                    continue
                price = PRICE_RE.findall(ln)[0]
                before = ln.split(price)[0].strip()
                if len(before) < 2 or len(before) > 120:
                    continue
                # отбросим явные “служебные” строки
                if MENU_KEYWORDS.search(before) and len(before.split()) <= 2:
                    continue
                items.append(
                    MenuItem(
                        site=site,
                        start_url=start_url,
                        source_url=source_url,
                        category=None,
                        name=before,
                        description=None,
                        price=price,
                    )
                )

        # дедуп
        uniq = {}
        for it in items:
            key = (it.source_url, (it.category or "").lower(), it.name.lower(), (it.price or ""))
            if key not in uniq:
                uniq[key] = it
        return list(uniq.values())

    # ----------------------------
    # Извлечение из PDF (если текстовый)
    # ----------------------------

    def extract_from_pdf(self, start_url: str, source_url: str, pdf_bytes: bytes) -> List[MenuItem]:
        try:
            import pdfplumber
        except Exception:
            # если pdfplumber не установлен — просто не парсим
            return []

        site = urlparse(start_url).netloc
        items: List[MenuItem] = []

        with pdfplumber.open(io.BytesIO(pdf_bytes)) as pdf:
            full_text = []
            for page in pdf.pages[:20]:  # ограничение на очень большие pdf
                t = page.extract_text() or ""
                if t:
                    full_text.append(t)
        text = "\n".join(full_text)
        lines = [norm_space(x) for x in text.splitlines() if norm_space(x)]

        # базовая эвристика строк: "Dish .... 12,50 €"
        for ln in lines:
            if not PRICE_RE.search(ln):
                continue
            price = PRICE_RE.findall(ln)[0]
            before = ln.split(price)[0].strip(" .•-–—:\t")
            if 2 <= len(before) <= 120:
                items.append(
                    MenuItem(
                        site=site,
                        start_url=start_url,
                        source_url=source_url,
                        category=None,
                        name=before,
                        description=None,
                        price=price,
                    )
                )

        # дедуп
        uniq = {}
        for it in items:
            key = (it.source_url, it.name.lower(), it.price or "")
            if key not in uniq:
                uniq[key] = it
        return list(uniq.values())

    # ----------------------------
    # Основной пайплайн
    # ----------------------------

    def scrape(self, start_url: str, max_pages: int = 35, max_menu_sources: int = 6) -> Tuple[List[MenuItem], Dict]:
        if not re.match(r"^https?://", start_url, re.IGNORECASE):
            start_url = "https://" + start_url

        pages = self.collect_internal_pages(start_url, max_pages=max_pages)
        candidates = self.find_menu_candidates(start_url, pages, max_candidates=12)

        diagnostics = {
            "start_url": start_url,
            "pages_crawled": len(pages),
            "menu_candidates_found": len(candidates),
            "menu_candidates": candidates[:max_menu_sources],
        }

        all_items: List[MenuItem] = []

        for src in candidates[:max_menu_sources]:
            r = self.fetch(src)
            time.sleep(self.sleep_sec)
            if not r:
                continue

            ctype = (r.headers.get("Content-Type") or "").lower()
            if "application/pdf" in ctype or url_is_pdf(src):
                # PDF
                try:
                    # NOTE: PDF extraction uses io.BytesIO, import lazily
                    global io
                    import io  # noqa
                    items = self.extract_from_pdf(start_url, src, r.content)
                except Exception:
                    items = []
            else:
                items = self.extract_from_html(start_url, src, r.text)

            all_items.extend(items)

        # финальная дедупликация по name+price+source_url
        uniq = {}
        for it in all_items:
            key = (it.source_url, it.name.lower(), (it.price or "").strip())
            if key not in uniq:
                uniq[key] = it

        final_items = list(uniq.values())
        diagnostics["items_extracted"] = len(final_items)

        return final_items, diagnostics


def save(items: List[MenuItem], out_csv: str, out_jsonl: str) -> None:
    rows = []
    for it in items:
        rows.append({
            "site": it.site,
            "start_url": it.start_url,
            "source_url": it.source_url,
            "category": it.category,
            "name": it.name,
            "description": it.description,
            "price": it.price,
        })
    df = pd.DataFrame(rows)
    df.to_csv(out_csv, index=False, encoding="utf-8")

    with open(out_jsonl, "w", encoding="utf-8") as f:
        for r in rows:
            f.write(json.dumps(r, ensure_ascii=False) + "\n")


def main():
    ap = argparse.ArgumentParser(description="Restaurant menu discovery scraper (HTML/PDF) without Selenium.")
    ap.add_argument("--url", required=True, help="Restaurant homepage URL (entry point).")
    ap.add_argument("--max_pages", type=int, default=35, help="How many internal pages to sample.")
    ap.add_argument("--max_menu_sources", type=int, default=6, help="How many menu sources to parse.")
    ap.add_argument("--sleep", type=float, default=0.3, help="Sleep between requests.")
    ap.add_argument("--timeout", type=int, default=20, help="Request timeout.")
    ap.add_argument("--retries", type=int, default=2, help="Retries.")
    ap.add_argument("--out_csv", default="restaurant_menu.csv", help="Output CSV.")
    ap.add_argument("--out_jsonl", default="restaurant_menu.jsonl", help="Output JSONL.")
    args = ap.parse_args()

    scraper = RestaurantMenuScraper(timeout=args.timeout, sleep_sec=args.sleep, retries=args.retries)
    items, diag = scraper.scrape(args.url, max_pages=args.max_pages, max_menu_sources=args.max_menu_sources)

    print(json.dumps(diag, ensure_ascii=False, indent=2))
    print(f"Extracted items: {len(items)}")
    save(items, args.out_csv, args.out_jsonl)
    print(f"Saved: {args.out_csv}, {args.out_jsonl}")


if __name__ == "__main__":
    main()