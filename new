# restaurant_menu_batch_fixed.py
# Batch restaurant menu scraper (HTML/PDF/iframe) WITHOUT Selenium.
# Input: sites.txt (one homepage per line)
# Output:
#   - restaurants_menu.csv / restaurants_menu.jsonl  (menu items)
#   - restaurants_menu_sources.csv / .jsonl          (menu sources found even if items not extracted)
#   - restaurants_diag.jsonl                         (diagnostics per site)

import re
import json
import time
import argparse
from dataclasses import dataclass, asdict
from typing import List, Optional, Tuple, Dict, Set
from urllib.parse import urljoin, urlparse, urldefrag

import requests
import pandas as pd
import tldextract
from bs4 import BeautifulSoup, Tag


DEFAULT_HEADERS = {
    "User-Agent": (
        "Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 "
        "(KHTML, like Gecko) Chrome/122.0 Safari/537.36"
    ),
    "Accept-Language": "ru,en;q=0.8,de;q=0.7,fr;q=0.6,it;q=0.6,es;q=0.6",
}

BAD_SCHEMES = ("mailto:", "tel:", "javascript:")

# Keywords to detect menu links (many languages)
MENU_KEYWORDS = re.compile(
    r"\b("
    r"menu|our menu|food|drinks|wine|cocktail|bar|kitchen|"
    r"speisekarte|getr[aä]nke|mittag|abend|"
    r"karte|weinkarte|"
    r"carta|men[uú]|bebidas|"
    r"carte|boissons|"
    r"меню|напитки|бар|кухня|винная карта|"
    r")\b",
    re.IGNORECASE,
)

# Price patterns (EUR/USD/GBP/RUB common)
PRICE_RE = re.compile(
    r"(?<!\w)("
    r"(?:€|\$|£)\s?\d{1,4}(?:[.,]\d{1,2})?"
    r"|\d{1,4}(?:[.,]\d{1,2})?\s?(?:€|eur|euro|руб\.?|р\.?|₽|usd|gbp)"
    r")",
    re.IGNORECASE,
)

BAD_TEXT_RE = re.compile(
    r"^(?:войти|login|sign in|sign-in|register|sign up|signup|"
    r"корзина|cart|basket|профиль|account|my account|search|поиск|"
    r"privacy|cookie|terms|условия|language|язык)$",
    re.IGNORECASE,
)

# Common “menu item” containers on many sites
MENU_BLOCK_SELECTORS = [
    ".menu-item", ".menu__item", ".menuItem", ".menuitem",
    ".dish", ".dish-item", ".dishItem",
    ".product", ".product-item", ".productItem",
    ".item", ".card", ".cards__item",
    "[class*='menu']", "[id*='menu']",
    "[class*='dish']", "[class*='product']",
    "tr", "li", "article", "section", "div"
]


def norm_space(s: str) -> str:
    return re.sub(r"\s+", " ", (s or "")).strip()


def get_reg_domain(url: str) -> str:
    e = tldextract.extract(url)
    return ".".join([p for p in [e.domain, e.suffix] if p]).lower()


def canonicalize_url(base_url: str, href: str) -> Optional[str]:
    if not href:
        return None
    href = href.strip()
    low = href.lower()
    if any(low.startswith(s) for s in BAD_SCHEMES):
        return None
    abs_url = urljoin(base_url, href)
    abs_url, _ = urldefrag(abs_url)
    p = urlparse(abs_url)
    if p.scheme not in ("http", "https"):
        return None
    return abs_url


def url_is_pdf(url: str) -> bool:
    return urlparse(url).path.lower().endswith(".pdf")


def looks_like_non_html_file(path: str) -> bool:
    path = (path or "").lower()
    return any(path.endswith(ext) for ext in [
        ".jpg", ".jpeg", ".png", ".webp", ".svg", ".zip", ".mp4", ".mov", ".avi", ".mp3"
    ])


def is_internal_loose(start_url: str, u: str, allowed_netlocs: Set[str]) -> bool:
    """
    Loose internal check:
    - allow same registrable domain
    - also allow any netloc observed from redirects / start page
    """
    try:
        netloc = urlparse(u).netloc.lower()
    except Exception:
        return False
    if netloc in allowed_netlocs:
        return True
    return get_reg_domain(start_url) == get_reg_domain(u)


@dataclass
class MenuItem:
    site: str
    start_url: str
    source_url: str
    category: Optional[str]
    name: str
    description: Optional[str]
    price: Optional[str]


@dataclass
class MenuSource:
    site: str
    start_url: str
    source_url: str
    source_type: str  # html / pdf / iframe / page_fallback
    score: int


class RestaurantMenuScraper:
    def __init__(self, timeout: int = 20, sleep_sec: float = 0.4, retries: int = 2):
        self.timeout = timeout
        self.sleep_sec = sleep_sec
        self.retries = retries
        self.sess = requests.Session()
        self.sess.headers.update(DEFAULT_HEADERS)

    def fetch(self, url: str) -> Optional[requests.Response]:
        for attempt in range(self.retries + 1):
            try:
                r = self.sess.get(url, timeout=self.timeout, allow_redirects=True)
                if r.status_code >= 400:
                    time.sleep(0.25 * (attempt + 1))
                    continue
                return r
            except Exception:
                time.sleep(0.35 * (attempt + 1))
        return None

    def fetch_html(self, url: str) -> Optional[str]:
        r = self.fetch(url)
        time.sleep(self.sleep_sec)
        return r.text if r else None

    def get_allowed_netlocs(self, start_url: str) -> Set[str]:
        """
        Fetch start_url once to capture redirects and allow www/non-www/m. variants.
        """
        allowed = set()
        try:
            r = self.fetch(start_url)
            time.sleep(self.sleep_sec)
            if r is None:
                allowed.add(urlparse(start_url).netloc.lower())
                return allowed

            # final URL after redirects
            final_url = r.url
            allowed.add(urlparse(start_url).netloc.lower())
            allowed.add(urlparse(final_url).netloc.lower())

            # also allow www variant
            nl = urlparse(final_url).netloc.lower()
            if nl.startswith("www."):
                allowed.add(nl[4:])
            else:
                allowed.add("www." + nl)

            # allow m. variant
            if nl.startswith("m."):
                allowed.add(nl[2:])
            else:
                allowed.add("m." + nl)

            return allowed
        except Exception:
            allowed.add(urlparse(start_url).netloc.lower())
            return allowed

    def collect_internal_pages(self, start_url: str, allowed_netlocs: Set[str], max_pages: int = 40) -> List[str]:
        """
        BFS crawl internal pages. Keeps PDFs as discovered links (handled later) but does not crawl into PDFs.
        """
        q = [start_url]
        seen = {start_url}
        out = []

        while q and len(out) < max_pages:
            url = q.pop(0)
            html = self.fetch_html(url)
            if not html:
                continue

            out.append(url)
            soup = BeautifulSoup(html, "lxml")

            for a in soup.select("a[href]"):
                abs_url = canonicalize_url(url, a.get("href"))
                if not abs_url:
                    continue

                # allow loose internal
                if not is_internal_loose(start_url, abs_url, allowed_netlocs):
                    continue

                path = urlparse(abs_url).path
                # do not crawl into non-html files
                if url_is_pdf(abs_url) or looks_like_non_html_file(path):
                    if abs_url not in seen:
                        seen.add(abs_url)
                    continue

                if abs_url not in seen and len(seen) < max_pages * 15:
                    seen.add(abs_url)
                    q.append(abs_url)

        return out

    def _score_url_as_menu_source(self, u: str, start_url: str) -> Optional[Tuple[int, str]]:
        """
        Returns (score, source_type) or None if not fetchable.
        """
        r = self.fetch(u)
        time.sleep(self.sleep_sec)
        if not r:
            return None

        ctype = (r.headers.get("Content-Type") or "").lower()
        if "application/pdf" in ctype or url_is_pdf(u):
            return (2000, "pdf")

        text = r.text or ""
        price_hits = len(PRICE_RE.findall(text))
        kw_hits_url = 1 if MENU_KEYWORDS.search(u) else 0
        kw_hits_page = len(MENU_KEYWORDS.findall(text[:40000] or ""))

        score = price_hits * 10 + kw_hits_page * 2 + kw_hits_url * 30
        return (score, "html")

    def find_menu_candidates(
        self,
        start_url: str,
        pages: List[str],
        allowed_netlocs: Set[str],
        max_candidates: int = 12,
        allow_external_iframes: bool = True,
    ) -> Tuple[List[MenuSource], Dict]:
        """
        Wide menu source discovery:
        - links by keywords
        - all PDFs found anywhere
        - iframes (often menu widgets; can be external)
        - fallback: pick crawled pages with highest count of prices
        Returns: (menu_sources_sorted, discovery_stats)
        """
        candidates: Set[str] = set()
        pdfs: Set[str] = set()
        iframes: Set[str] = set()

        scanned_pages = 0

        for p in pages:
            html = self.fetch_html(p)
            if not html:
                continue
            scanned_pages += 1
            soup = BeautifulSoup(html, "lxml")

            # anchor links
            for a in soup.select("a[href]"):
                text = norm_space(a.get_text(" ", strip=True))
                if BAD_TEXT_RE.match(text):
                    continue
                abs_url = canonicalize_url(p, a.get("href"))
                if not abs_url:
                    continue

                # PDFs: keep even if no keywords
                if url_is_pdf(abs_url):
                    # mostly internal PDFs; external PDFs are less common but can exist
                    if is_internal_loose(start_url, abs_url, allowed_netlocs):
                        pdfs.add(abs_url)
                    continue

                # internal pages
                if not is_internal_loose(start_url, abs_url, allowed_netlocs):
                    continue

                # keyword hit => candidate
                if MENU_KEYWORDS.search(text) or MENU_KEYWORDS.search(abs_url):
                    candidates.add(abs_url)

            # iframe sources (menu widgets)
            for fr in soup.select("iframe[src]"):
                src = canonicalize_url(p, fr.get("src"))
                if not src:
                    continue
                if allow_external_iframes:
                    iframes.add(src)
                else:
                    if is_internal_loose(start_url, src, allowed_netlocs):
                        iframes.add(src)

        # typical paths fallback
        for t in ["/menu", "/menue", "/speisekarte", "/karte", "/food", "/drinks", "/bar", "/carta", "/carte", "/меню"]:
            candidates.add(urljoin(start_url, t))

        # combine
        candidates_all = set(candidates) | set(pdfs) | set(iframes)

        scored: List[MenuSource] = []
        scored_raw: List[Tuple[int, str]] = []

        for u in candidates_all:
            s = self._score_url_as_menu_source(u, start_url)
            if s is None:
                continue
            score, stype = s
            # Slight boost for iframe candidates so we don't miss widgets
            if u in iframes and stype != "pdf":
                score += 50
                stype = "iframe"
            if u in pdfs:
                stype = "pdf"
            scored.append(MenuSource(
                site=urlparse(start_url).netloc,
                start_url=start_url,
                source_url=u,
                source_type=stype,
                score=int(score),
            ))
            scored_raw.append((int(score), u))

        # sort by score desc
        scored.sort(key=lambda x: x.score, reverse=True)

        # keep strong ones first
        strong = [ms for ms in scored if ms.score >= 20][:max_candidates]

        # if none strong: fallback to pages with most prices
        fallback_sources: List[MenuSource] = []
        if not strong:
            page_price_scores: List[Tuple[int, str]] = []
            for p in pages:
                html = self.fetch_html(p)
                if not html:
                    continue
                ph = len(PRICE_RE.findall(html))
                page_price_scores.append((ph, p))
            page_price_scores.sort(key=lambda x: x[0], reverse=True)
            for ph, p in page_price_scores[:3]:
                if ph <= 0:
                    continue
                fallback_sources.append(MenuSource(
                    site=urlparse(start_url).netloc,
                    start_url=start_url,
                    source_url=p,
                    source_type="page_fallback",
                    score=int(ph * 10),
                ))

        final_sources = strong if strong else fallback_sources

        stats = {
            "pages_total": len(pages),
            "pages_scanned_for_sources": scanned_pages,
            "candidates_kw": len(candidates),
            "candidates_pdfs": len(pdfs),
            "candidates_iframes": len(iframes),
            "candidates_total_unique": len(candidates_all),
        }
        return final_sources, stats

    def extract_from_html(self, start_url: str, source_url: str, html: str) -> List[MenuItem]:
        soup = BeautifulSoup(html, "lxml")
        for t in soup(["script", "style", "noscript"]):
            t.decompose()

        site = urlparse(start_url).netloc
        items: List[MenuItem] = []

        # 0) Try common block selectors first (higher recall)
        for sel in MENU_BLOCK_SELECTORS:
            try:
                blocks = soup.select(sel)
            except Exception:
                continue
            # avoid scanning absurd amounts
            for block in blocks[:600]:
                txt = norm_space(block.get_text(" ", strip=True))
                if not txt or len(txt) < 8:
                    continue
                if not PRICE_RE.search(txt):
                    continue

                price = PRICE_RE.findall(txt)[0]
                before = txt.split(price)[0].strip()
                if not before:
                    continue

                # get a likely name
                name = None
                h = block.find(["h1", "h2", "h3", "h4", "strong"])
                if h:
                    htxt = norm_space(h.get_text(" ", strip=True))
                    if 2 <= len(htxt) <= 100:
                        name = htxt

                if not name:
                    # split common separators
                    parts = re.split(r"\s[-–—:]\s|\s{2,}", before, maxsplit=1)
                    name = norm_space(parts[0])[:120] if parts else before[:120]

                if not name or len(name) < 2:
                    continue

                # category: nearest previous h2/h3
                cat = None
                parent = block
                for _ in range(6):
                    if not isinstance(parent, Tag):
                        break
                    prev = parent.find_previous(["h2", "h3"])
                    if prev:
                        c = norm_space(prev.get_text(" ", strip=True))
                        if c and len(c) <= 60:
                            cat = c
                            break
                    parent = parent.parent

                items.append(MenuItem(
                    site=site,
                    start_url=start_url,
                    source_url=source_url,
                    category=cat,
                    name=name,
                    description=None,
                    price=price
                ))

        # 1) Second pass: blocks around price nodes (helps with sparse markup)
        price_nodes = []
        for node in soup.find_all(string=PRICE_RE):
            if isinstance(node, str):
                price_nodes.append(node.parent)

        def nearest_block(tag: Tag) -> Tag:
            cur = tag
            for _ in range(5):
                if not isinstance(cur, Tag):
                    break
                if cur.name in {"li", "tr", "article", "section", "div"}:
                    return cur
                cur = cur.parent
            return tag

        seen_blocks = set()
        for pn in price_nodes:
            if not isinstance(pn, Tag):
                continue
            block = nearest_block(pn)
            bid = id(block)
            if bid in seen_blocks:
                continue
            seen_blocks.add(bid)

            block_text = norm_space(block.get_text(" ", strip=True))
            if not block_text:
                continue

            price = PRICE_RE.findall(block_text)[0] if PRICE_RE.search(block_text) else None
            if not price:
                continue

            before = block_text
            idx = before.find(price)
            if idx > 0:
                before = before[:idx].strip()

            heading = block.find(["h1", "h2", "h3", "h4", "strong"])
            name = None
            if heading:
                htxt = norm_space(heading.get_text(" ", strip=True))
                if 2 <= len(htxt) <= 100:
                    name = htxt
            if not name:
                parts = re.split(r"\s[-–—:]\s|\s{2,}", before, maxsplit=1)
                name = norm_space(parts[0])[:120] if parts and parts[0] else None
            if not name or len(name) < 2:
                continue

            items.append(MenuItem(
                site=site,
                start_url=start_url,
                source_url=source_url,
                category=None,
                name=name,
                description=None,
                price=price
            ))

        # 2) Fallback: line-based extraction
        if len(items) < 5:
            text = soup.get_text("\n", strip=True)
            lines = [norm_space(x) for x in text.splitlines() if norm_space(x)]
            for ln in lines:
                if not PRICE_RE.search(ln):
                    continue
                price = PRICE_RE.findall(ln)[0]
                before = ln.split(price)[0].strip()
                if 2 <= len(before) <= 120 and not (MENU_KEYWORDS.search(before) and len(before.split()) <= 2):
                    items.append(MenuItem(
                        site=site,
                        start_url=start_url,
                        source_url=source_url,
                        category=None,
                        name=before,
                        description=None,
                        price=price
                    ))

        # Deduplicate
        uniq: Dict[Tuple[str, str, str], MenuItem] = {}
        for it in items:
            key = (it.source_url, it.name.lower(), (it.price or "").strip())
            if key not in uniq:
                uniq[key] = it
        return list(uniq.values())

    def extract_from_pdf(self, start_url: str, source_url: str, pdf_bytes: bytes) -> List[MenuItem]:
        try:
            import io
            import pdfplumber
        except Exception:
            return []

        site = urlparse(start_url).netloc
        items: List[MenuItem] = []

        try:
            with pdfplumber.open(io.BytesIO(pdf_bytes)) as pdf:
                full_text = []
                for page in pdf.pages[:25]:
                    t = page.extract_text() or ""
                    if t:
                        full_text.append(t)
            text = "\n".join(full_text)
        except Exception:
            return []

        lines = [norm_space(x) for x in (text or "").splitlines() if norm_space(x)]
        for ln in lines:
            if not PRICE_RE.search(ln):
                continue
            price = PRICE_RE.findall(ln)[0]
            before = ln.split(price)[0].strip(" .•-–—:\t")
            if 2 <= len(before) <= 120:
                items.append(MenuItem(
                    site=site,
                    start_url=start_url,
                    source_url=source_url,
                    category=None,
                    name=before,
                    description=None,
                    price=price
                ))

        uniq: Dict[Tuple[str, str], MenuItem] = {}
        for it in items:
            key = (it.name.lower(), (it.price or "").strip())
            if key not in uniq:
                uniq[key] = it
        return list(uniq.values())

    def scrape_one(
        self,
        start_url_raw: str,
        max_pages: int = 40,
        max_menu_sources: int = 6,
        allow_external_iframes: bool = True,
    ) -> Tuple[List[MenuItem], List[MenuSource], Dict]:
        # normalize URL
        start_url = start_url_raw.strip()
        if not re.match(r"^https?://", start_url, re.IGNORECASE):
            start_url = "https://" + start_url

        allowed_netlocs = self.get_allowed_netlocs(start_url)

        pages = self.collect_internal_pages(start_url, allowed_netlocs, max_pages=max_pages)

        sources, src_stats = self.find_menu_candidates(
            start_url=start_url,
            pages=pages,
            allowed_netlocs=allowed_netlocs,
            max_candidates=12,
            allow_external_iframes=allow_external_iframes,
        )

        sources_top = sources[:max_menu_sources]

        diag = {
            "start_url": start_url,
            "site": urlparse(start_url).netloc,
            "allowed_netlocs": sorted(list(allowed_netlocs))[:10],
            "pages_crawled": len(pages),
            "menu_sources_found": len(sources),
            "menu_sources_top": [asdict(s) for s in sources_top],
            "source_discovery": src_stats,
        }

        all_items: List[MenuItem] = []

        for src in sources_top:
            r = self.fetch(src.source_url)
            time.sleep(self.sleep_sec)
            if not r:
                continue

            ctype = (r.headers.get("Content-Type") or "").lower()

            if "application/pdf" in ctype or url_is_pdf(src.source_url):
                items = self.extract_from_pdf(start_url, src.source_url, r.content)
            else:
                items = self.extract_from_html(start_url, src.source_url, r.text or "")

            all_items.extend(items)

        # Final dedup across sources
        uniq: Dict[Tuple[str, str, str], MenuItem] = {}
        for it in all_items:
            key = (it.start_url, it.name.lower(), (it.price or "").strip())
            if key not in uniq:
                uniq[key] = it

        diag["items_extracted"] = len(uniq)
        return list(uniq.values()), sources_top, diag


def read_sites(path: str) -> List[str]:
    out = []
    with open(path, "r", encoding="utf-8") as f:
        for line in f:
            s = line.strip()
            if not s or s.startswith("#"):
                continue
            out.append(s)
    return out


def save_items(items: List[MenuItem], out_csv: str, out_jsonl: str) -> None:
    rows = [asdict(it) for it in items]
    df = pd.DataFrame(rows)
    df.to_csv(out_csv, index=False, encoding="utf-8")
    with open(out_jsonl, "w", encoding="utf-8") as f:
        for r in rows:
            f.write(json.dumps(r, ensure_ascii=False) + "\n")


def save_sources(sources: List[MenuSource], out_csv: str, out_jsonl: str) -> None:
    rows = [asdict(s) for s in sources]
    df = pd.DataFrame(rows)
    df.to_csv(out_csv, index=False, encoding="utf-8")
    with open(out_jsonl, "w", encoding="utf-8") as f:
        for r in rows:
            f.write(json.dumps(r, ensure_ascii=False) + "\n")


def save_diagnostics(diags: List[Dict], out_path: str) -> None:
    with open(out_path, "w", encoding="utf-8") as f:
        for d in diags:
            f.write(json.dumps(d, ensure_ascii=False) + "\n")


def main():
    ap = argparse.ArgumentParser(description="Batch restaurant menu scraper (HTML/PDF/iframe) without Selenium.")
    ap.add_argument("--sites", required=True, help="Path to sites.txt (one homepage URL per line).")
    ap.add_argument("--max_pages", type=int, default=40, help="Internal pages to crawl per site.")
    ap.add_argument("--max_menu_sources", type=int, default=6, help="How many menu sources to parse per site.")
    ap.add_argument("--sleep", type=float, default=0.4, help="Sleep between requests.")
    ap.add_argument("--timeout", type=int, default=20, help="Request timeout.")
    ap.add_argument("--retries", type=int, default=2, help="Retries.")
    ap.add_argument("--allow_external_iframes", action="store_true", help="Allow external iframe menu widgets (recommended).")
    ap.add_argument("--out_csv", default="restaurants_menu.csv", help="Output menu items CSV.")
    ap.add_argument("--out_jsonl", default="restaurants_menu.jsonl", help="Output menu items JSONL.")
    ap.add_argument("--out_sources_csv", default="restaurants_menu_sources.csv", help="Output menu sources CSV.")
    ap.add_argument("--out_sources_jsonl", default="restaurants_menu_sources.jsonl", help="Output menu sources JSONL.")
    ap.add_argument("--out_diag", default="restaurants_diag.jsonl", help="Diagnostics JSONL.")
    args = ap.parse_args()

    sites = read_sites(args.sites)
    scraper = RestaurantMenuScraper(timeout=args.timeout, sleep_sec=args.sleep, retries=args.retries)

    all_items: List[MenuItem] = []
    all_sources: List[MenuSource] = []
    diags: List[Dict] = []

    for i, s in enumerate(sites, 1):
        try:
            items, sources, diag = scraper.scrape_one(
                s,
                max_pages=args.max_pages,
                max_menu_sources=args.max_menu_sources,
                allow_external_iframes=args.allow_external_iframes,
            )
            all_items.extend(items)
            all_sources.extend(sources)
            diags.append(diag)

            print(
                f"[{i}/{len(sites)}] {diag['start_url']} | "
                f"pages={diag['pages_crawled']} sources={diag['menu_sources_found']} "
                f"items={diag['items_extracted']}"
            )
        except Exception as e:
            url_norm = s if s.startswith("http") else ("https://" + s)
            diags.append({
                "start_url": url_norm,
                "site": urlparse(url_norm).netloc,
                "error": str(e),
            })
            print(f"[{i}/{len(sites)}] {s} -> ERROR: {e}")

    save_items(all_items, args.out_csv, args.out_jsonl)
    save_sources(all_sources, args.out_sources_csv, args.out_sources_jsonl)
    save_diagnostics(diags, args.out_diag)

    print(f"Saved menu items: {args.out_csv}, {args.out_jsonl}")
    print(f"Saved menu sources: {args.out_sources_csv}, {args.out_sources_jsonl}")
    print(f"Saved diagnostics: {args.out_diag}")


if __name__ == "__main__":
    main()